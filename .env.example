MPVM_API_URL=https://srv-siem.local
# MPVM_TOKEN_URL=https://srv-siem.local:3334/connect/token
MPVM_USERNAME=
MPVM_PASSWORD=
MPVM_CLIENT_ID=mpx
MPVM_CLIENT_SECRET=
MPVM_SCOPE=authorization offline_access mpx.api ptkb.api
# MPVM_ACCESS_TOKEN=
MPVM_UTC_OFFSET=+05:00
# Set true only for lab/self-signed TLS.
MPVM_INSECURE=false
MPVM_TIMEOUT=120
MPVM_BACKGROUND_REQUEST_LIMIT=10
MPVM_ASSET_CARD_REQUEST_WORKERS=8
MPVM_ASSET_CARD_REFRESH_WORKERS=3
MPVM_SCAN_POSTPROCESS_WORKERS=3
MPVM_SCAN_ASSET_PROCESS_WORKERS=1
MPVM_DOCKER_DYNAMIC_GROUP_ITERATIONS=3
MPVM_DOCKER_DYNAMIC_GROUP_SETTLE_SECONDS=10
MPVM_DOCKER_DYNAMIC_GROUP_TIMEOUT_SECONDS=120
MPVM_DOCKER_DYNAMIC_GROUP_POLL_SECONDS=5
MPVM_DOCKER_DYNAMIC_GROUP_RETENTION_SECONDS=600
MPVM_PASSPORT_DETAIL_WORKERS=10
MPVM_PASSPORT_DETAIL_TTL_HOURS=24
MPVM_ASSET_METADATA_TTL_SECONDS=3600
MPVM_LOG_LEVEL=INFO
MPVM_LOG_DIR=output/logs
MPVM_LOG_MAX_BYTES=104857600
MPVM_LOG_BACKUP_COUNT=10
MPVM_LOG_RETENTION_DAYS=14
MPVM_DEBUG_PAYLOADS=false
MPVM_DEBUG_PAYLOAD_MAX_BYTES=1048576
MPVM_DEBUG_PAYLOAD_RETENTION_HOURS=24
MPVM_DATABASE_URL=postgresql://mpvm:mpvm@postgres:5432/mpvm
MPVM_EXPORTS_DIR=exports
MPVM_AUTOMATION_SCHEDULER_POLL_SECONDS=30
# Optional global webhook; secret is used for X-MPVM-Signature HMAC-SHA256.
MPVM_AUTOMATION_WEBHOOK_URL=
MPVM_AUTOMATION_WEBHOOK_SECRET=
MPVM_COVERAGE_STALE_DAYS=7
# Local application access. On an empty database this creates the first admin.
MPVM_BOOTSTRAP_ADMIN_USERNAME=admin
MPVM_BOOTSTRAP_ADMIN_PASSWORD=
MPVM_BOOTSTRAP_ADMIN_DISPLAY_NAME=Administrator
MPVM_AUTH_SESSION_HOURS=12
# Enable when the application is served over HTTPS.
MPVM_AUTH_COOKIE_SECURE=false
